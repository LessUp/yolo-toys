# Backend runtime configuration
PORT=8000
LOG_LEVEL=INFO
MODEL_NAME=yolov8s.pt
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45
MAX_DET=300
# DEVICE can be auto-selected if unset; options: cpu, mps, cuda:0
# DEVICE=cpu
# Skip model warmup at startup (set to any non-empty value)
# SKIP_WARMUP=1

# CORS allowlist (comma-separated). Use '*' to allow all.
ALLOW_ORIGINS=*

# Upload & concurrency limits
MAX_UPLOAD_MB=10
MAX_CONCURRENCY=4

# Model defaults
# DEFAULT_CAPTION_MODEL=Salesforce/blip-image-captioning-base
# DEFAULT_VQA_MODEL=Salesforce/blip-vqa-base

# Inference tuning
# BLIP_MAX_TOKENS=50
# GROUNDING_TEXT_THRESHOLD=0.25
# WARMUP_IMAGE_SIZE=640
# GZIP_MIN_SIZE=1000
